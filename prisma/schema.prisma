model ApiPerformanceRule {
  id       String            @id @default(auto()) @map("_id") @db.ObjectId
  configId String            @db.ObjectId
  config   PriceEngineConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  metricKey         String // Matches API_METRICS_BY_SPORT keys
  effectType        ApiEffectType
  adjustmentPercent Float // Percentage: 8.0 = ±8%
  triggerCondition  Json? // Optional: { "applyPerUnit": true, "operator": ">=" }
  sortOrder         Int           @default(0)
  isActive          Boolean       @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([configId, metricKey, effectType])
  @@index([configId, isActive, metricKey])
  @@map("api_performance_rules")
