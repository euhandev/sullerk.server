generator client {
  provider = "prisma-client-js"
}

generator dbml {
  provider = "prisma-dbml-generator"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Embedded types for Posts (MongoDB composite types) ─────

model User {
  id                      String         @id @default(auto()) @map("_id") @db.ObjectId
  username                String
  email                   String         @unique
  contactNo               String         @default("")
  password                String?
  provider                AuthProvider   @default(LOCAL)
  googleId                String?        @unique
  lang                    Lang           @default(ENG)
  role                    Role           @default(CUSTOMER)
  avatar                  String?        @default("")
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  status                  Status         @default(ACTIVE)
  dob                     DateTime?
  fcmToken                String?        @default("")
  resetPasswordOtp        String?
  resetPasswordOtpExpires DateTime?
  admin                   Admin?
  customer                Customer?
  notifications           Notification[]

  // ─── Chat relations ───
  roomParticipants RoomParticipant[]
  chats            Chat[]
  chatReactions    ChatReaction[]

  @@unique([username])
  @@index([email, role, status, createdAt])
  @@map("users")
}

model Admin {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  fullName  String
  address   String?
  intro     String?
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resolvedDisputes Dispute[] @relation("ResolvedBy")

  @@map("admins")
}

model Customer {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  userId     String      @unique @db.ObjectId
  fullName   String?
  bloodGroup BloodGroup?
  gender     Gender?
  address    String?     @default("")
  city       String?     @default("")
  postcode   String?     @default("")
  state      String?     @default("")
  country    String?     @default("")
  favSport   FavSport?   @default(OTHER)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  user       User        @relation(fields: [userId], references: [id])

  listings Listing[] @relation("ListingOwner")

  ordersAsBuyer   Order[]          @relation("OrderBuyer")
  ordersAsSeller  Order[]          @relation("OrderSeller")
  watchlists      Watchlist[]
  paymentMethods  PaymentMethod[]
  listingHistory  ListingHistory[]
  Report          Report[]
  dealsAsBuyer    Deal[]           @relation("DealBuyer")
  dealsAsSeller   Deal[]           @relation("DealSeller")
  starredListings StarredListing[]
  shares          ListingShare[]

  posts     Post[]
  reports   Repost[]
  comments  Comment[]
  reactions Reaction[]
  stars     StarredPost[]

  followers Follow[] @relation("Following")
  following Follow[] @relation("Follower")
  blockedBy           BlockedUser[] @relation("BlockedBy")
  blockedUsers        BlockedUser[] @relation("BlockedUser")

  balance      Float         @default(0.0) // Virtual wallet
  stripeConnectId String?    // Stripe Connect Account ID for payouts
  transactions Transaction[]
  withdrawals  Withdrawal[]

  communityMembers   CommunityMember[]
  communityPosts     CommunityPost[]
  communityComments  CommunityComment[]
  communityReactions CommunityReaction[]
  communityReposts   CommunityRepost[]
  communityStars     CommunityStarredPost[]

  pollVotes     PollVote[]
  subscriptions Subscription[]
  payments      Payment[]
  activityLogs  ActivityLog[]

  exchangeSent     ExchangeOffer[] @relation("ExchangeSender")
  exchangeReceived ExchangeOffer[] @relation("ExchangeReceiver")

  raisedDisputes Dispute[] @relation("RaisedBy")

  @@index([createdAt])
  @@map("customers")
}

enum FavSport {
  FOOTBALL
  BASKETBALL
  RUGBY
  CRICKET
  TENNIS
  BADMINTON
  VOLLEYBALL
  BOXING
  UFC
  F1
  BASEBALL
  HOCKEY
  GOLF
  ATHLETICS
  OTHER
}

model Follow {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  followerId  String   @db.ObjectId
  follower    Customer @relation(name: "Follower", fields: [followerId], references: [id])
  followingId String   @db.ObjectId
  following   Customer @relation(name: "Following", fields: [followingId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([followerId, followingId])
  @@map("follows")
}

model BlockedUser {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  blockedById   String   @db.ObjectId
  blockedBy     Customer @relation(name: "BlockedBy", fields: [blockedById], references: [id])
  blockedUserId String   @db.ObjectId
  blockedUser   Customer @relation(name: "BlockedUser", fields: [blockedUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([blockedById, blockedUserId])
  @@map("blocked_users")
}

// post 

model Post {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  customerId  String     @db.ObjectId
  customer    Customer   @relation(fields: [customerId], references: [id])
  aiAnalysis  String?    @default("")
  type        PostType[]
  description String?    @default("")

  images FileItem[]

  // ─── External Link ───
  externalLink String? @default("")

  // ─── Linked Listing ───
  listingId String?  @db.ObjectId
  listing   Listing? @relation(fields: [listingId], references: [id])

  // ─── Poll ───
  pollQuestion       String?
  pollOptions        PollOption[] @relation("PollOptions")
  pollExpiresAt      DateTime?
  pollMultipleChoice Boolean      @default(false)

  // ─── Engagement ───
  reports   Repost[]
  comments  Comment[]
  reactions Reaction[]
  stars     StarredPost[]
  pollVotes PollVote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files File[]
}

model PollOption {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  text      String
  votes     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  post      Post       @relation("PollOptions", fields: [postId], references: [id], onDelete: Cascade)
  postId    String     @db.ObjectId
  PollVote  PollVote[]

  @@map("pollOptions")
}

model PollVote {
  id         String     @id @default(auto()) @map("_id") @db.ObjectId
  pollId     String     @db.ObjectId
  poll       Post       @relation(fields: [pollId], references: [id])
  customerId String     @db.ObjectId
  customer   Customer   @relation(fields: [customerId], references: [id])
  optionId   String     @db.ObjectId
  option     PollOption @relation(fields: [optionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pollId, customerId])
  @@map("poll_votes")
}

model Reaction {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  postId      String       @db.ObjectId
  post        Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  reactedById String       @db.ObjectId
  customer    Customer     @relation(fields: [reactedById], references: [id])
  type        ReactionType @default(LIKE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([postId, reactedById])
  @@map("reactions")
}

model DealListing {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  dealId    String          @db.ObjectId
  deal      Deal            @relation(fields: [dealId], references: [id])
  listingId String          @db.ObjectId
  listing   Listing         @relation(fields: [listingId], references: [id])
  type      DealListingType @default(MINE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([dealId, listingId])
  @@map("deal_listings")
}

model Repost {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  postId       String   @db.ObjectId
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  reportedById String   @db.ObjectId
  customer     Customer @relation(fields: [reportedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([postId, reportedById])
  @@map("reposts")
}

model StarredPost {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  postId       String   @db.ObjectId
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  reportedById String   @db.ObjectId
  customer     Customer @relation(fields: [reportedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([postId, reportedById])
  @@map("starred_posts")
}

model Comment {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  postId String @db.ObjectId
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id])

  body String

  parentId String?   @db.ObjectId
  parent   Comment?  @relation("CommentToComment", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children Comment[] @relation("CommentToComment")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comments")
}

model Community {
  id           String                 @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  description  String?
  tags         String[]
  type         CommunityType
  posts        CommunityPost[]
  comments     CommunityComment[]
  reactions    CommunityReaction[]
  reposts      CommunityRepost[]
  starredPosts CommunityStarredPost[]
  members      CommunityMember[]
  heroImg      String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@map("communities")
}

model CommunityMember {
  id          String                @id @default(auto()) @map("_id") @db.ObjectId
  customerId  String                @db.ObjectId
  customer    Customer              @relation(fields: [customerId], references: [id])
  communityId String                @db.ObjectId
  community   Community             @relation(fields: [communityId], references: [id])
  userType    CommunityUserType
  status      CommunityMemberStatus
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([communityId, customerId])
  @@map("community_members")
}

enum CommunityMemberStatus {
  PENDING
  ACTIVE
  BLOCKED
}

enum CommunityUserType {
  ADMIN
  MODERATOR
  MEMBER
}

model CommunityPost {
  id          String                 @id @default(auto()) @map("_id") @db.ObjectId
  customerId  String                 @db.ObjectId
  customer    Customer               @relation(fields: [customerId], references: [id])
  communityId String                 @db.ObjectId
  community   Community              @relation(fields: [communityId], references: [id])
  type        PostType[]
  text        String?
  files       File[]
  reports     CommunityRepost[]
  comments    CommunityComment[]
  reactions   CommunityReaction[]
  stars       CommunityStarredPost[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@map("community_posts")
}

model CommunityReaction {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  postId      String        @db.ObjectId
  post        CommunityPost @relation(fields: [postId], references: [id])
  communityId String        @db.ObjectId
  community   Community     @relation(fields: [communityId], references: [id])
  reactedById String        @db.ObjectId
  customer    Customer      @relation(fields: [reactedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([postId, reactedById])
  @@map("community_reactions")
}

model CommunityRepost {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  postId       String        @db.ObjectId
  post         CommunityPost @relation(fields: [postId], references: [id])
  reportedById String        @db.ObjectId
  customer     Customer      @relation(fields: [reportedById], references: [id])
  communityId  String        @db.ObjectId
  community    Community     @relation(fields: [communityId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([postId, reportedById])
  @@map("community_reposts")
}

model CommunityStarredPost {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  postId      String        @db.ObjectId
  post        CommunityPost @relation(fields: [postId], references: [id])
  starredById String        @db.ObjectId
  customer    Customer      @relation(fields: [starredById], references: [id])
  communityId String        @db.ObjectId
  community   Community     @relation(fields: [communityId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([postId, starredById])
  @@map("community_starred_posts")
}

model CommunityComment {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  postId      String        @db.ObjectId
  post        CommunityPost @relation(fields: [postId], references: [id])
  communityId String        @db.ObjectId
  community   Community     @relation(fields: [communityId], references: [id])
  customerId  String        @db.ObjectId
  customer    Customer      @relation(fields: [customerId], references: [id])

  body String

  parentId String?            @db.ObjectId
  parent   CommunityComment?  @relation("CommunityCommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children CommunityComment[] @relation("CommunityCommentReplies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("community_comments")
}

enum CommunityType {
  PUBLIC
  PRIVATE
}

enum PostType {
  TEXT
  IMG
  PRODUCT
  POLL
  LINK
}

enum AuthProvider {
  LOCAL
  GOOGLE
  APPLE
  FACEBOOK
  GITHUB
}

enum ReactionType {
  LIKE
  LOVE
  HAHA
  WOW
  SAD
  ANGRY
}

model Listing {
  id                    String          @id @default(auto()) @map("_id") @db.ObjectId
  title                 String?
  sport                 String
  league                String?
  teamOrCountry         String
  playerOrManagerName   String?
  category              ListingCategory
  seasonOrYear          String
  kitType               String? // Home, Away, Third, Special Edition, Match Worn, N/A
  description           String
  signatureType         SignatureKey   @default(NONE)
  photoProofType        ProofViewKey   @default(NO_PROOF)
  videoProofType        ProofViewKey   @default(NO_PROOF)
  coaStatus             COAStatus       @default(NO_COA)
  companyAuthentication String?         @default("Not Authenticated")
  cardNumbered          String?
  cardFeature           String?
  cardGrade             String?
  format                SaleFormat      @default(BUY_NOW)

  photos      FileItem[]
  proofPhotos FileItem[]
  proofVideos FileItem[]
  coaFiles    FileItem[]
  files       File[]

  isTradingEnable    Boolean @default(false)
  isHoldPrice        Boolean @default(false)
  isPauseListing     Boolean @default(false)
  estimatedBaseValue Float   @default(0.0)
  initialPrice       Float   @default(0.0)

  allowOffers     Boolean       @default(false)
  autoPriceAdjust Boolean       @default(false)
  status          ListingStatus @default(PENDING)
  sharesCount     Int           @default(0)

  ownerId String   @db.ObjectId
  owner   Customer @relation("ListingOwner", fields: [ownerId], references: [id])

  acquiredDate DateTime?

  orders     Order[]
  watchlists Watchlist[]
  reports    Report[]

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  ListingHistories ListingHistory[]
  dealListings     DealListing[]
  starredListings  StarredListing[]
  collections      CollectionListing[]
  posts            Post[]
  shares           ListingShare[]

  disputes Dispute[]

  calculatedBasePrice     Float? // Engine-calculated price snapshot
  displayPrice            Float? // Final price after seller adjustment
  priceEngineConfigId     String?               @db.ObjectId
  priceEngineConfig       PriceEngineConfig?    @relation(fields: [priceEngineConfigId], references: [id])
  priceBreakdown          Json? // Audit trail of multipliers applied
  appliedHonours          String[] // Honour keys applied at creation
  appliedApiMetrics       Json? // { "Goal": 2, "Assist": 1 } snapshot
  lastApiRecalcAt         DateTime? // Last time API cron updated price
  isPriceLocked           Boolean               @default(false)
  sellerAdjustmentPercent Float? // % deviation applied by seller (within range)
  priceCalculationLogs    PriceCalculationLog[]

  @@map("listings")
}

type FileItem {
  fileId String
  url    String
}

model Collection {
  id          String              @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String
  listings    CollectionListing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("collections")
}

model CollectionListing {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  collectionId String     @db.ObjectId
  collection   Collection @relation(fields: [collectionId], references: [id])
  listingId    String     @db.ObjectId
  listing      Listing    @relation(fields: [listingId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([collectionId, listingId])
  @@map("collection_listings")
}

model Deal {
  id       String        @id @default(auto()) @map("_id") @db.ObjectId
  buyerId  String        @db.ObjectId
  buyer    Customer      @relation("DealBuyer", fields: [buyerId], references: [id])
  sellerId String        @db.ObjectId
  seller   Customer      @relation("DealSeller", fields: [sellerId], references: [id])
  note     String?
  status   DealStatus    @default(APPROTCHED)
  listings DealListing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("deals")
}

enum DealStatus {
  APPROTCHED
  ACCEPTED
  REJECTED
}

enum DealListingType {
  MINE
  OTHERS
}

model Report {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  listingId    String       @db.ObjectId
  listing      Listing      @relation(fields: [listingId], references: [id])
  reportedById String       @db.ObjectId
  customer     Customer     @relation(fields: [reportedById], references: [id])
  reportNote   String
  status       ReportStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reports")
}

model StarredListing {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id])
  listingId  String   @db.ObjectId
  listing    Listing  @relation(fields: [listingId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([customerId, listingId])
  @@map("starred_listings")
}

enum ReportStatus {
  PENDING
  ACTIVE
  COMPLETED
}

model ListingHistory {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  listingId  String   @db.ObjectId
  listing    Listing  @relation(fields: [listingId], references: [id])
  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([listingId, customerId])
  @@map("listing_histories")
}

model Order {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber String   @unique
  listingId   String   @db.ObjectId
  listing     Listing  @relation(fields: [listingId], references: [id])
  buyerId     String   @db.ObjectId
  buyer       Customer @relation("OrderBuyer", fields: [buyerId], references: [id])
  sellerId    String   @db.ObjectId
  seller      Customer @relation("OrderSeller", fields: [sellerId], references: [id])

  totalAmount    Float // Total paid by buyer
  platformFee    Float @default(0.0) // Deducted amount
  sellerEarnings Float @default(0.0) // Net amount for seller

  status          OrderStatus @default(PENDING_PAYMENT)
  stripeSessionId String? // Track Stripe checkout
  trackingNo      String?
  type            OrderType   @default(PURCHASE)

  disputes Dispute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orders")
  transactions Transaction[]
}

model ExchangeOffer {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  senderId String   @db.ObjectId
  sender   Customer @relation("ExchangeSender", fields: [senderId], references: [id])

  receiverId String   @db.ObjectId
  receiver   Customer @relation("ExchangeReceiver", fields: [receiverId], references: [id])

  // Support for Bundles (multiple listings on either side)
  senderListingIds   String[] @db.ObjectId
  receiverListingIds String[] @db.ObjectId

  senderTotalValue   Float @default(0.0)
  receiverTotalValue Float @default(0.0)
  balanceToPay       Float @default(0.0) // Difference to balance the trade

  note            String?
  status          ExchangeStatus @default(PENDING)
  paymentStatus   String         @default("NONE") // NONE, PENDING, PAID
  stripeSessionId String?

  // Negotiation History (Offer -> Re-offer chain)
  parentOfferId String?         @db.ObjectId
  parentOffer   ExchangeOffer?  @relation("CounterOffers", fields: [parentOfferId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  counterOffers ExchangeOffer[] @relation("CounterOffers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("exchange_offers")
  transactions Transaction[]
}

model Transaction {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id])

  amount Float // Positive for credits, negative for debits
  type   TransactionType

  orderId         String? @db.ObjectId
  order           Order?  @relation(fields: [orderId], references: [id])
  exchangeOfferId String? @db.ObjectId
  exchangeOffer   ExchangeOffer? @relation(fields: [exchangeOfferId], references: [id])
  withdrawalId    String? @db.ObjectId
  withdrawal      Withdrawal? @relation(fields: [withdrawalId], references: [id])

  description String? // e.g. "Payment for Listing X"
  status      TransactionStatus @default(COMPLETED)
  createdAt   DateTime          @default(now())

  @@map("transactions")
}

model Dispute {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  listingId String?  @db.ObjectId
  listing   Listing? @relation(fields: [listingId], references: [id])

  orderId String? @db.ObjectId
  order   Order?  @relation(fields: [orderId], references: [id])

  raisedById String   @db.ObjectId
  raisedBy   Customer @relation("RaisedBy", fields: [raisedById], references: [id])

  resolvedById String? @db.ObjectId
  resolvedBy   Admin?  @relation("ResolvedBy", fields: [resolvedById], references: [id])

  type   DisputeType
  status DisputeStatus @default(OPEN)

  reason         String
  details        String?
  resolutionNote String?

  evidence FileItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("disputes")
}

model Watchlist {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id])
  listingId  String   @db.ObjectId
  listing    Listing  @relation(fields: [listingId], references: [id])

  createdAt DateTime @default(now())

  @@unique([customerId, listingId])
  @@map("watchlists")
}

model ListingShare {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id])
  listingId  String   @db.ObjectId
  listing    Listing  @relation(fields: [listingId], references: [id])

  createdAt DateTime @default(now())

  @@unique([customerId, listingId])
  @@map("listing_shares")
}

model PaymentMethod {
  id         String            @id @default(auto()) @map("_id") @db.ObjectId
  customerId String            @db.ObjectId
  customer   Customer          @relation(fields: [customerId], references: [id])
  type       PaymentMethodType
  provider   String
  accountNo  String?
  isDefault  Boolean           @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payment_methods")
}

model Withdrawal {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  customerId      String           @db.ObjectId
  customer        Customer         @relation(fields: [customerId], references: [id])
  
  amount          Float
  paymentMethodId String?          @db.ObjectId // Optional if using Stripe Connect directly
  
  status          WithdrawalStatus @default(PENDING)
  adminNote       String?          
  stripeTransferId String?         // Reference to Stripe transfer
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("withdrawals")
  transactions Transaction[]
}

enum WithdrawalStatus {
  PENDING
  COMPLETED
  REJECTED
}

model SubscriptionPlan {
  id                   String                 @id @default(auto()) @map("_id") @db.ObjectId
  plan                 SubscribePlan          @default(MONTHLY) // Monthly or Yearly
