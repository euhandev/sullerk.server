// PRICE ENGINE CONFIG (Root Model - One Per Sport)
// ─────────────────────────────────────────────────────────────

model PriceEngineConfig {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  sport       String  @unique // "Football", "Basketball", etc.
  isActive    Boolean @default(true)
  description String?

  // ─── GLOBAL CONTROLS TAB ─────────────────────────────
  platformFeePercent       Float @default(5.0) // e.g., 5.0 = 5%
  sellerAdjustRangePercent Float @default(10.0) // ±% sellers can adjust
  apiRecalcIntervalGames   Int   @default(2) // Recalc every N matches/events

  // ─── RELATIONS ─────────────────────────────────────
  baseValues           BaseValue[]
  proofMultipliers     ProofMultiplierGroup[]
  signatureMultipliers SignatureMultiplier[]
  authMultipliers      AuthMultiplier[]
  cardMultipliers      CardMultiplierGroup[]
  honourMultipliers    HonourMultiplier[]
  apiPerformanceRules  ApiPerformanceRule[]
  calculationLogs      PriceCalculationLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  Listing   Listing[]

  @@index([sport, isActive])
  @@map("price_engine_configs")
}

// ─────────────────────────────────────────────────────────────
// BASE VALUES TAB
// ─────────────────────────────────────────────────────────────

model BaseValue {
  id       String            @id @default(auto()) @map("_id") @db.ObjectId
  configId String            @db.ObjectId
  config   PriceEngineConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  category  ListingCategory // Reuse your existing enum: SHIRT, BOOTS, CARD, GLOVES, MATCH_BALL, SHORTS, OTHER
  basePrice Float // Base price in GBP

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([configId, category])
  @@map("base_values")
}

