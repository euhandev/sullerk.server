generator client {
  provider = "prisma-client-js"
}

generator dbml {
  provider = "prisma-dbml-generator"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Embedded types for Posts (MongoDB composite types) ─────

model User {
  id                      String         @id @default(auto()) @map("_id") @db.ObjectId
  username                String
  email                   String         @unique
  contactNo               String         @default("")
  password                String?
  provider                AuthProvider   @default(LOCAL)
  googleId                String?        @unique
  lang                    Lang           @default(ENG)
  role                    Role           @default(CUSTOMER)
  avatar                  String?        @default("")
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  status                  Status         @default(ACTIVE)
  dob                     DateTime?
  fcmToken                String?        @default("")
  resetPasswordOtp        String?
  resetPasswordOtpExpires DateTime?
  admin                   Admin?
  customer                Customer?
  notifications           Notification[]

  // ─── Chat relations ───
  roomParticipants RoomParticipant[]
  chats            Chat[]
  chatReactions    ChatReaction[]

  @@unique([username])
  @@index([email, role, status, createdAt])
  @@map("users")
}

model Admin {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  fullName  String
  address   String?
  intro     String?
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

model Customer {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  userId     String      @unique @db.ObjectId
  fullName   String?
  bloodGroup BloodGroup?
  gender     Gender?
  address    String?     @default("")
  city       String?     @default("")
  postcode   String?     @default("")
  state      String?     @default("")
  country    String?     @default("")
  favSport   FavSport?   @default(OTHER)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  user       User        @relation(fields: [userId], references: [id])

  listings       Listing[]   @relation("ListingOwner")

  ordersAsBuyer  Order[]         @relation("OrderBuyer")
  ordersAsSeller Order[]         @relation("OrderSeller")
  disputes       Dispute[]
  watchlists     Watchlist[]
  paymentMethods PaymentMethod[]
  listingHistory ListingHistory[]
  Report         Report[]
  dealsAsBuyer   Deal[]           @relation("DealBuyer")
  dealsAsSeller  Deal[]           @relation("DealSeller")
  starredListings StarredListing[]
  shares          ListingShare[]

  posts          Post[]
  reports        Repost[]
  comments       Comment[]
  reactions      Reaction[]
  stars          StarredPost[]

  followers           Follower[]    @relation("Follower")
  followedBy          Follower[]    @relation("Following")
  following           Following[]   @relation("Follower")
  followedByFollowing Following[]   @relation("Following")
  blockedBy           BlockedUser[] @relation("BlockedBy")
  blockedUsers        BlockedUser[] @relation("BlockedUser")

  communityMembers   CommunityMember[]
  communityPosts     CommunityPost[]
  communityComments  CommunityComment[]
  communityReactions CommunityReaction[]
  communityReposts   CommunityRepost[]
  communityStars     CommunityStarredPost[]

  pollVotes     PollVote[]
  subscriptions Subscription[]
  payments      Payment[]
  activityLogs  ActivityLog[]

  @@index([createdAt])
  @@map("customers")
}

enum FavSport {
  FOOTBALL
  BASKETBALL
  RUGBY
  CRICKET
  TENNIS
  BADMINTON
  VOLLEYBALL
  BOXING
  UFC
  F1
  BASEBALL
  HOCKEY
  GOLF
  ATHLETICS
  OTHER
}

model Follower {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  followerId  String   @db.ObjectId
  follower    Customer @relation(name: "Follower", fields: [followerId], references: [id])
  followingId String   @db.ObjectId
  following   Customer @relation(name: "Following", fields: [followingId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Following {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  followerId  String   @db.ObjectId
  follower    Customer @relation(name: "Follower", fields: [followerId], references: [id])
  followingId String   @db.ObjectId
  following   Customer @relation(name: "Following", fields: [followingId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlockedUser {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  blockedById   String   @db.ObjectId
  blockedBy     Customer @relation(name: "BlockedBy", fields: [blockedById], references: [id])
  blockedUserId String   @db.ObjectId
  blockedUser   Customer @relation(name: "BlockedUser", fields: [blockedUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// post 

model Post {
  id         String     @id @default(auto()) @map("_id") @db.ObjectId
  customerId String     @db.ObjectId
  customer   Customer   @relation(fields: [customerId], references: [id])
  aiAnalysis String?    @default("")
  type       PostType[]
  description String?   @default("")
  
  images     FileItem[]

  // ─── External Link ───
  externalLink String? @default("")

  // ─── Linked Listing ───
  listingId    String?    @db.ObjectId
  listing      Listing?   @relation(fields: [listingId], references: [id])

  // ─── Poll ───
  pollQuestion       String?
  pollOptions        PollOption[] @relation("PollOptions")
  pollExpiresAt      DateTime?
  pollMultipleChoice Boolean      @default(false)

  // ─── Engagement ───
  reports   Repost[]
  comments  Comment[]
  reactions Reaction[]
  stars     StarredPost[]
  pollVotes PollVote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  files File[]
}

model PollOption {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  text      String
  votes     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  post      Post       @relation("PollOptions", fields: [postId], references: [id])
  postId    String     @db.ObjectId
  PollVote  PollVote[]

  @@map("pollOptions")
}

model PollVote {
  id         String     @id @default(auto()) @map("_id") @db.ObjectId
  pollId     String     @db.ObjectId
  poll       Post       @relation(fields: [pollId], references: [id])
  customerId String     @db.ObjectId
  customer   Customer   @relation(fields: [customerId], references: [id])
  optionId   String     @db.ObjectId
  option     PollOption @relation(fields: [optionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pollId, customerId])
  @@map("poll_votes")
}

model Reaction {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  postId      String       @db.ObjectId
  post        Post         @relation(fields: [postId], references: [id])
  reactedById String       @db.ObjectId
  customer    Customer     @relation(fields: [reactedById], references: [id])
  type        ReactionType @default(LIKE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([postId, reactedById])
  @@map("reactions")
}


model DealListing {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  dealId    String          @db.ObjectId
  deal      Deal            @relation(fields: [dealId], references: [id])
  listingId String          @db.ObjectId
  listing   Listing         @relation(fields: [listingId], references: [id])
  type      DealListingType @default(MINE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([dealId, listingId])
  @@map("deal_listings")
}



model Repost {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  postId       String   @db.ObjectId
  post         Post     @relation(fields: [postId], references: [id])
  reportedById String   @db.ObjectId
  customer     Customer @relation(fields: [reportedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([postId, reportedById])
  @@map("reposts")
}

model StarredPost {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  postId       String   @db.ObjectId
  post         Post     @relation(fields: [postId], references: [id])
  reportedById String   @db.ObjectId
  customer     Customer @relation(fields: [reportedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([postId, reportedById])
  @@map("starred_posts")
}

model Comment {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  postId String @db.ObjectId
  post   Post   @relation(fields: [postId], references: [id])

  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id])

  body String

  parentId String?   @db.ObjectId
  parent   Comment?  @relation("CommentToComment", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children Comment[] @relation("CommentToComment")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comments")
}

model Community {
  id           String                 @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  description  String?
  tags         String[]
  type         CommunityType
  posts        CommunityPost[]
  comments     CommunityComment[]
  reactions    CommunityReaction[]
  reposts      CommunityRepost[]
  starredPosts CommunityStarredPost[]
  members      CommunityMember[]
  heroImg      String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@map("communities")
}

model CommunityMember {
  id          String                @id @default(auto()) @map("_id") @db.ObjectId
  customerId  String                @db.ObjectId
  customer    Customer              @relation(fields: [customerId], references: [id])
  communityId String                @db.ObjectId
  community   Community             @relation(fields: [communityId], references: [id])
  userType    CommunityUserType
  status      CommunityMemberStatus
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([communityId, customerId])
  @@map("community_members")
}

enum CommunityMemberStatus {
  PENDING
  ACTIVE
  BLOCKED
}

enum CommunityUserType {
  ADMIN
  MODERATOR
  MEMBER
}

model CommunityPost {
  id          String                 @id @default(auto()) @map("_id") @db.ObjectId
  customerId  String                 @db.ObjectId
  customer    Customer               @relation(fields: [customerId], references: [id])
  communityId String                 @db.ObjectId
  community   Community              @relation(fields: [communityId], references: [id])
  type        PostType[]
  text        String?
  files       File[]
  reports     CommunityRepost[]
  comments    CommunityComment[]
  reactions   CommunityReaction[]
  stars       CommunityStarredPost[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@map("community_posts")
}

model CommunityReaction {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  postId      String        @db.ObjectId
  post        CommunityPost @relation(fields: [postId], references: [id])
  communityId String        @db.ObjectId
  community   Community     @relation(fields: [communityId], references: [id])
  reactedById String        @db.ObjectId
  customer    Customer      @relation(fields: [reactedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([postId, reactedById])
  @@map("community_reactions")
}

model CommunityRepost {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  postId       String        @db.ObjectId
  post         CommunityPost @relation(fields: [postId], references: [id])
  reportedById String        @db.ObjectId
  customer     Customer      @relation(fields: [reportedById], references: [id])
  communityId  String        @db.ObjectId
  community    Community     @relation(fields: [communityId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([postId, reportedById])
  @@map("community_reposts")
}

model CommunityStarredPost {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  postId       String        @db.ObjectId
  post         CommunityPost @relation(fields: [postId], references: [id])
  starredById String        @db.ObjectId
  customer     Customer      @relation(fields: [starredById], references: [id])
  communityId  String        @db.ObjectId
  community    Community     @relation(fields: [communityId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([postId, starredById])
  @@map("community_starred_posts")
}

model CommunityComment {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  postId      String        @db.ObjectId
  post        CommunityPost @relation(fields: [postId], references: [id])
  communityId String        @db.ObjectId
  community   Community     @relation(fields: [communityId], references: [id])
  customerId  String        @db.ObjectId
  customer    Customer      @relation(fields: [customerId], references: [id])

  body String

  parentId String?            @db.ObjectId
  parent   CommunityComment?  @relation("CommunityCommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children CommunityComment[] @relation("CommunityCommentReplies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("community_comments")
}

enum CommunityType {
  PUBLIC
  PRIVATE
}

enum PostType {
  TEXT
  IMG
  PRODUCT
  POLL
  LINK
}

enum AuthProvider {
  LOCAL
  GOOGLE
  APPLE
  FACEBOOK
  GITHUB
}

enum ReactionType {
  LIKE
  LOVE
  HAHA
  WOW
  SAD
  ANGRY
}

model Listing {
  id                    String          @id @default(auto()) @map("_id") @db.ObjectId
  title                 String?
  sport                 String
  teamOrCountry         String
  playerOrManagerName   String?
  category              ListingCategory
  seasonOrYear          String
  kitType               String? // Home, Away, Third, Special Edition, Match Worn, N/A
  description           String
  signatureType         SignatureType   @default(NONE)
  photoProofType        PhotoProofType  @default(NONE)
  videoProofType        VideoProofType  @default(NONE)
  coaStatus             COAStatus       @default(NO_COA)
  companyAuthentication String?         @default("Not Authenticated")
  format                SaleFormat      @default(BUY_NOW)

  photos      FileItem[]
  proofPhotos FileItem[]
  proofVideos FileItem[]
  coaFiles    FileItem[]
  files       File[]

  isTradingEnable    Boolean @default(false)
  isHoldPrice        Boolean @default(false)
  isPauseListing     Boolean @default(false)
  estimatedBaseValue Float   @default(0.0)
  initialPrice       Float   @default(0.0)

  allowOffers     Boolean       @default(false)
  autoPriceAdjust Boolean       @default(false)
  status          ListingStatus @default(PENDING)
  sharesCount     Int           @default(0)


  ownerId String   @db.ObjectId
  owner   Customer @relation("ListingOwner", fields: [ownerId], references: [id])

  acquiredDate DateTime?

  orders     Order[]
  watchlists Watchlist[]
  reports    Report[]

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  ListingHistories ListingHistory[]
  dealListings     DealListing[]
  starredListings  StarredListing[]
  collections      CollectionListing[]
  posts            Post[]
  shares           ListingShare[]

  @@map("listings")
}

type FileItem {
  fileId String
  url    String
}


model Collection {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String
  listings    CollectionListing[]

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("collections")
}

model CollectionListing {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  collectionId String     @db.ObjectId
  collection   Collection @relation(fields: [collectionId], references: [id])
  listingId    String     @db.ObjectId
  listing      Listing    @relation(fields: [listingId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([collectionId, listingId])
  @@map("collection_listings")
}


model Deal {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  buyerId   String     @db.ObjectId
  buyer     Customer   @relation("DealBuyer", fields: [buyerId], references: [id])
  sellerId  String     @db.ObjectId
  seller    Customer   @relation("DealSeller", fields: [sellerId], references: [id])
  note      String?
  status    DealStatus @default(APPROTCHED)
  listings  DealListing[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("deals")
}

enum DealStatus {
  APPROTCHED
  ACCEPTED
  REJECTED
}

enum DealListingType {
  MINE
  OTHERS
}





model Report {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  listingId    String       @db.ObjectId
  listing      Listing      @relation(fields: [listingId], references: [id])
  reportedById String       @db.ObjectId
  customer     Customer     @relation(fields: [reportedById], references: [id])
  reportNote   String
  status       ReportStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reports")
}


model StarredListing {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id])
  listingId  String   @db.ObjectId
  listing    Listing  @relation(fields: [listingId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([customerId, listingId])
  @@map("starred_listings")
}

enum ReportStatus {
  PENDING
  ACTIVE
  COMPLETED
}

model ListingHistory {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  listingId  String   @db.ObjectId
  listing    Listing  @relation(fields: [listingId], references: [id])
  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([listingId, customerId])
  @@map("listing_histories")
}


model Order {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber String      @unique
  listingId   String      @db.ObjectId
  listing     Listing     @relation(fields: [listingId], references: [id])
  buyerId     String      @db.ObjectId

  buyer       Customer    @relation("OrderBuyer", fields: [buyerId], references: [id])
  sellerId    String      @db.ObjectId
  seller      Customer    @relation("OrderSeller", fields: [sellerId], references: [id])
  amount      Float
  status      OrderStatus @default(PENDING)
  trackingNo  String?
  type        OrderType   @default(PURCHASE)

  disputes Dispute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orders")
}

model Dispute {
  id         String        @id @default(auto()) @map("_id") @db.ObjectId
  orderId    String        @db.ObjectId
  order      Order         @relation(fields: [orderId], references: [id])
  raisedById String        @db.ObjectId
  raisedBy   Customer      @relation(fields: [raisedById], references: [id])
  type       DisputeType
  status     DisputeStatus @default(OPEN)
  reason     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("disputes")
}

model Watchlist {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id])
  listingId  String   @db.ObjectId
  listing    Listing  @relation(fields: [listingId], references: [id])

  createdAt DateTime @default(now())

  @@unique([customerId, listingId])
  @@map("watchlists")
}

model ListingShare {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id])
  listingId  String   @db.ObjectId
  listing    Listing  @relation(fields: [listingId], references: [id])

  createdAt DateTime @default(now())

  @@unique([customerId, listingId])
  @@map("listing_shares")
}


model PaymentMethod {
  id         String            @id @default(auto()) @map("_id") @db.ObjectId
  customerId String            @db.ObjectId
  customer   Customer          @relation(fields: [customerId], references: [id])
  type       PaymentMethodType
  provider   String
  accountNo  String?
  isDefault  Boolean           @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payment_methods")
}

model SubscriptionPlan {
  id                   String                 @id @default(auto()) @map("_id") @db.ObjectId
  plan                 SubscribePlan          @default(MONTHLY) // Monthly or Yearly
  status               SubscriptionPlanStatus @default(ACTIVE)
  name                 String?                @default("")
  description          String?                @default("")
  trialPeriod          Boolean                @default(true) // Is 14-day free trial included?
  price                Float                  @default(0) // Subscription price
  stripePriceId        String                 @default("") // Stripe price reference
  features             String[]               @default([])
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  enrolledSubscription Subscription[]
  payments             Payment[]

  @@map("subscription_plans")
}

model Subscription {
  id                   String             @id @default(auto()) @map("_id") @db.ObjectId
  customerId           String?            @db.ObjectId
  subscriptionPlanId   String?            @db.ObjectId
  subscriptionStatus   SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId String?
  stripeCustomerId     String?
  expiresAt            DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  cancelRequest        Boolean            @default(false)
  customer             Customer?          @relation(fields: [customerId], references: [id])
  subscriptionPlan     SubscriptionPlan?  @relation(fields: [subscriptionPlanId], references: [id])
  payments             Payment[]

  // @@unique([clinicId, subscriptionPlanId])
  @@map("subscriptions")
}

model Payment {
  id                 String            @id @default(auto()) @map("_id") @db.ObjectId
  customerId         String            @db.ObjectId
  amount             Float
  currency           String?           @default("USD")
  paymentDate        DateTime
  paymentStatus      PaymentStatus
  subscriptionId     String?           @db.ObjectId
  subscriptionPlanId String?           @db.ObjectId
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  customer           Customer          @relation(fields: [customerId], references: [id])
  subscription       Subscription?     @relation(fields: [subscriptionId], references: [id])
  subscriptionPlan   SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id])

  @@map("payments")
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
  PAST_DUE
  INACTIVE
}

enum SubscribePlan {
  FREE
  MONTHLY
  YEARLY
}

enum SubscriptionPlanStatus {
  ACTIVE
  INACTIVE
}

enum PaymentStatus {
  REQUIRES_PAYMENT_METHOD
  REQUIRES_CONFIRMATION
  REQUIRES_ACTION
  PROCESSING
  REQUIRES_CAPTURE
  CANCELED
  SUCCEEDED
  REFUNDED
  PARTIALLY_REFUNDED
  FAILED
}

model PricingConfig {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  key         String  @unique
  value       String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pricing_configs")
}

enum ListingCategory {

  SHIRT
  BOOTS
  CARD
  GLOVES
  MATCH_BALL
  SHORTS
  OTHER
}

enum SignatureType {
  NONE
  PARTIAL
  FULL
  DEDICATED
}

enum PhotoProofType {
  NONE
  PARTIAL
  FULL
  WITH_ATHLETE
}

enum VideoProofType {
  NONE
  LISTING
  SIGNING
  WITH_ATHLETE
}

enum COAStatus {
  NO_COA
  COA_INCLUDED
  SELF_CERTIFIED
}



enum SaleFormat {
  BUY_NOW
  TRADE_ONLY
  BUY_AND_TRADE
}

enum ListingStatus {

  ACTIVE
  PAUSED
  PENDING
  SOLD
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum OrderType {
  PURCHASE
  TRADE
}

enum DisputeType {
  DISPUTE
  REFUND
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
}

enum PaymentMethodType {
  BANK_ACCOUNT
  PAYPAL
  CARD
}

enum TransactionType {
  PAYMENT
  WITHDRAWAL
  FEE
  REFUND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model Newsletter {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId String?  @db.ObjectId
  email      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("newsletters")
}

model File {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  name            String?
  url             String
  key             String?
  type            FileType       @default(DOC)
  purpose         FileAs         @default(PHOTOS)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  listing         Listing?       @relation(fields: [listingId], references: [id])
  listingId       String?        @db.ObjectId
  uploadedById    String?        @db.ObjectId
  isPending       Boolean        @default(false)
  context         FileContext    @default(CREATE)

  postId          String?        @db.ObjectId

  post            Post?          @relation(fields: [postId], references: [id])
  communityPostId String?        @db.ObjectId
  communityPost   CommunityPost? @relation(fields: [communityPostId], references: [id])

  module          FileModule     @default(LISTING)

  @@map("files")
}

enum FileModule {
  LISTING
  POST
  COMMUNITY
}

enum FileAs {
  PHOTOS
  PROOF_PHOTO
  PROOF_VIDEO
  COA_FILE
  COM_AUTH
  COMMUNITY_HERO
}

enum FileContext {
  CREATE
  EDIT
}

model Notification {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  userId    String           @db.ObjectId
  type      NotificationType
  name      String
  body      String
  data      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id])

  @@map("notifications")
}

enum NotificationType {
  SUBSCRIPTION_REMINDER
  GROUP_ASSIGNMENT
  MEMBER_REGISTERED
  POST_ENGAGEMENT
  NEED_HELP_REQUESTED
  DISPUTE
  REPORT
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CUSTOMER
}

enum Status {
  ACTIVE
  INACTIVE

  @@map("status")
}

enum Lang {
  ENG
  RON
  HUN
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum Gender {
  MALE
  FEMALE
  OTHERS
}

enum FileType {
  DOC
  IMAGE
  VIDEO
  AUDIO
}

// ─── Chat System ────────────────────────────────────────

enum RoomType {
  PRIVATE
  GROUP
}

enum ChatRole {
  ADMIN
  MODERATOR
  MEMBER
}

enum ChatType {
  TEXT
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
  SYSTEM
}

model Room {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  avatar        String?
  type          RoomType          @default(PRIVATE)
  creatorId     String            @db.ObjectId
  participants  RoomParticipant[]
  messages      Chat[]
  lastMessage   String?
  lastMessageAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rooms")
}

model RoomParticipant {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  roomId     String    @db.ObjectId
  room       Room      @relation(fields: [roomId], references: [id])
  userId     String    @db.ObjectId
  user       User      @relation(fields: [userId], references: [id])
  role       ChatRole  @default(MEMBER)
  joinedAt   DateTime  @default(now())
  mutedUntil DateTime?
  lastReadAt DateTime?

  @@unique([roomId, userId])
  @@map("room_participants")
}

model Chat {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  roomId    String   @db.ObjectId
  room      Room     @relation(fields: [roomId], references: [id])
  senderId  String   @db.ObjectId
  sender    User     @relation(fields: [senderId], references: [id])
  message   String?
  type      ChatType @default(TEXT)
  isEdited  Boolean  @default(false)
  isDeleted Boolean  @default(false)

  // ─── Reply threading ───
  replyToId String? @db.ObjectId
  replyTo   Chat?   @relation("ChatReply", fields: [replyToId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies   Chat[]  @relation("ChatReply")

  // ─── Attachments ───
  attachments ChatFile[]

  // ─── Reactions ───
  reactions ChatReaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roomId, createdAt])
  @@map("chats")
}

model ChatFile {
  id     String   @id @default(auto()) @map("_id") @db.ObjectId
  chatId String   @db.ObjectId
  chat   Chat     @relation(fields: [chatId], references: [id])
  url    String
  name   String?
  type   FileType @default(IMAGE)
  size   Int?

  createdAt DateTime @default(now())

  @@map("chat_files")
}

model ChatReaction {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  chatId String @db.ObjectId
  chat   Chat   @relation(fields: [chatId], references: [id])
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])
  emoji  String

  createdAt DateTime @default(now())

  @@unique([chatId, userId, emoji])
  @@map("chat_reactions")
}

model ActivityLog {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  customerId String?   @db.ObjectId
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  action      ActionType
  section     String? // Which section was modified (e.g., "section_5")
  description String
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([customerId, createdAt])
  @@map("activity_logs")
}

// activity logs types should be based on whole websites functionality
enum ActionType {
  LOGIN
  UPDATE_PROFILE
  UPDATE_PASSWORD
  RESET_PASSWORD
}
