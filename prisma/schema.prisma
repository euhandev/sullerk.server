// ─────────────────────────────────────────────────────────────
// PRICE CALCULATION LOG (Audit Trail)
// ─────────────────────────────────────────────────────────────

model PriceCalculationLog {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  listingId String?  @db.ObjectId
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  configId String            @db.ObjectId
  config   PriceEngineConfig @relation(fields: [configId], references: [id])

  inputContext   Json // { category, proofPhoto, proofVideo, signature, auth, honours[], apiMetrics{} }
  breakdown      Json // Step-by-step calculation trace
  finalPrice     Float
  currency       String             @default("GBP")
  platformFee    Float
  sellerRangeMin Float
  sellerRangeMax Float
  trigger        CalculationTrigger @default(MANUAL)
  calculatedBy   String?            @db.ObjectId

  createdAt DateTime @default(now())

  @@index([listingId, createdAt])
  @@index([configId, createdAt])
  @@map("price_calculation_logs")
}

enum CalculationTrigger {
  MANUAL
  API_RECALC
  CONFIG_UPDATE
}

