  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (groupId, ruleKey) [unique]
  }
}

Table honour_multipliers {
  id String [pk]
  configId String [not null]
  config price_engine_configs [not null]
  honourKey String [not null]
  multiplier Float [not null]
  sportContext String
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (configId, honourKey) [unique]
  }
}

Table api_performance_rules {
  id String [pk]
  configId String [not null]
  config price_engine_configs [not null]
  metricKey String [not null]
  effectType ApiEffectType [not null]
  adjustmentPercent Float [not null]
  triggerCondition Json
  sortOrder Int [not null, default: 0]
  isActive Boolean [not null, default: true]
  createdAt DateTime [default: `now()`, not null]
  updatedAt DateTime [not null]

  indexes {
    (configId, metricKey, effectType) [unique]
  }
}

Table price_calculation_logs {
  id String [pk]
  listingId String
  listing listings
  configId String [not null]
  config price_engine_configs [not null]
  inputContext Json [not null]
  breakdown Json [not null]
  finalPrice Float [not null]
  currency String [not null, default: 'GBP']
  platformFee Float [not null]
  sellerRangeMin Float [not null]
  sellerRangeMax Float [not null]
  trigger CalculationTrigger [not null, default: 'MANUAL']
  calculatedBy String
  createdAt DateTime [default: `now()`, not null]
}

Table Follower {
  followersId String [ref: > Follower.id]
  followingId String [ref: > Following.id]
}

Table Following {
  followedbyId String [ref: > Follower.id]
  followedbyfollowingId String [ref: > Following.id]
}

